[Unit]
Description=Model Update Server
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/model-update-server
EnvironmentFile=/etc/model-update-server/model-update-server.env
ExecStart=/opt/model-update-server/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
